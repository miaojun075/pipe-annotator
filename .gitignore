# ============================================================
# PipeAnnotator — Root .gitignore (Open Core)
# Strategy: /* ignores all root items, then ! un-ignores what we want.
# Subdirectories (src/, demo/) have their own .gitignore.
# ============================================================

# ── Ignore everything at root level ──
/*

# ── Un-ignore directories we want to track ──
!/src/
!/demo/

# ── Un-ignore specific root files ──
!/.gitignore
!/.gitattributes
!/LICENSE
!/README.md
!/CONTRIBUTING.md
!/PIPELINE.md
!/config.yaml
!/requirements.txt
!/requirements-api.txt
!/main.py
!/rename_pipe.py
!/merge_training_data.py
!/run.bat
!/setup.bat