# Line ending normalization
* text=auto

# Windows scripts need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source code: LF (standard)
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.npy binary
